{
  "name": "giopic",
  "displayName": "GioPic",
  "version": "0.0.1",
  "description": "GioPic,是一款免费的上传扩展程序提供lsky,EasyImages,chevereto,阿里云oss,AWS S3,等程序的文件上传",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run clear && cross-env NODE_ENV=development run-p dev:*",
    "dev:prepare": "esno scripts/prepare.ts",
    "dev:main": "vite && cross-env NODE_ENV=development",
    "dev:background": "pnpm run build:background -- --mode development",
    "dev:content": "pnpm run build:content -- --mode development",
    "dev:upload": "pnpm run build:upload -- --mode development",
    "dev:fullDOM": "pnpm run build:fullDOM -- --mode development",
    "preview": "vite preview",
    "build": "pnpm run clear && run-p build:*",
    "build:web": "vite build",
    "build:prepare": "esno scripts/prepare.ts",
    "build:background": "vite build --config vite.config.background.ts",
    "build:content": "vite build --config vite.config.content.ts",
    "build:upload": "vite build --config vite.config.upload.ts",
    "build:fullDOM": "vite build --config vite.config.fullDOM.ts",
    "type-check": "vue-tsc --build",
    "clear": "rimraf --glob dist",
    "firefox": "cross-env NODE_ENV=development EXTENSION=firefox run-p dev:*"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.733.0",
    "@iconify-json/hugeicons": "^1.2.3",
    "@iconify-json/ic": "^1.2.2",
    "@iconify-json/material-symbols": "^1.2.12",
    "@iconify-json/ph": "^1.2.2",
    "@intlify/devtools-types": "^11.1.3",
    "@tsconfig/node22": "^22.0.0",
    "@types/ali-oss": "^6.16.11",
    "@types/chrome": "^0.0.299",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.10",
    "@types/webextension-polyfill": "^0.12.2",
    "@unocss/preset-icons": "^65.4.3",
    "@unocss/preset-rem-to-px": "^65.4.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "@vueuse/core": "^12.5.0",
    "ali-oss": "^6.22.0",
    "axios": "^1.7.9",
    "chokidar": "^4.0.3",
    "cos-js-sdk-v5": "^1.8.7",
    "cross-env": "^7.0.3",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.0",
    "naive-ui": "^2.41.0",
    "npm-run-all": "^4.1.5",
    "pinia": "^2.3.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "unocss": "^65.4.3",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^7.7.0",
    "vue": "^3.5.13",
    "vue-i18n": "11.1.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0",
    "webextension-polyfill": "^0.12.0"
  }
}